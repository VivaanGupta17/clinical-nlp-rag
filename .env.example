# ClinicalRAG Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── NCBI Entrez API ─────────────────────────────────────────────────────────
# Get your key at: https://www.ncbi.nlm.nih.gov/account/
# Without key: 3 requests/sec. With key: 10 requests/sec.
NCBI_API_KEY=your_ncbi_api_key_here

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here

# ─── Azure OpenAI (optional) ─────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ─── QuickUMLS (optional) ─────────────────────────────────────────────────────
# Path to QuickUMLS installation for UMLS query expansion
QUICKUMLS_PATH=/usr/local/share/quickumls

# ─── HuggingFace ─────────────────────────────────────────────────────────────
HUGGINGFACE_TOKEN=hf_your_token_here   # Required for gated models (Llama, etc.)

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
